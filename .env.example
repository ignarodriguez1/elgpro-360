# ==============================================================================
# ELG Pro — .env.example
# Derivado del inventario REAL de process.env (no de un template genérico).
# Copiá a .env y completá. NUNCA commitees .env con valores reales.
# Leyenda: [REQ] requerida · [OPC] opcional · [PROD] setear en Vercel · [AUTO] la pone Vercel
# ==============================================================================

# ──────────────────────────────────────────────
# Base de datos — Neon (Postgres) + Prisma 7
# ──────────────────────────────────────────────
# [REQ] Runtime. En prod = URL POOLED de Neon (host con "-pooler"). La lee
# src/lib/prisma.ts vía el adapter PrismaPg.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1"

# [PROD] Conexión DIRECTA (sin pooler) — SOLO migraciones Prisma.
# 🟡 OJO: el código aún NO la lee (prisma.config.ts usa DATABASE_URL). Queda
# lista para cuando la cablemos. En Neon, migrar por la pooled puede fallar.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# [OPC] Alternativa a DATABASE_URL para DEV local: si DATABASE_URL falta, el
# código arma la URL con estas partes (buildDatabaseUrl). En prod NO se usan.
DB_USER="elgpro"
DB_PASSWORD="elgpro360"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="elgpro360"

# ──────────────────────────────────────────────
# Auth.js v5 (next-auth)
# ──────────────────────────────────────────────
# [REQ] Firma el JWT de sesión Y el ticket del WS. Generar: openssl rand -base64 33
AUTH_SECRET="reemplazar-por-secreto-generado"
# [PROD] Confiar en el host del proxy (Vercel).
AUTH_TRUST_HOST="true"
# [PROD] Dominio público real de producción.
AUTH_URL="https://tu-dominio-de-prod"

# ──────────────────────────────────────────────
# Storage (selector de proveedor)
# ──────────────────────────────────────────────
# [REQ] "gcs" (prod) · "cloudinary" · "local" (dev → public/uploads/). Default: cloudinary
STORAGE_PROVIDER="gcs"

# ── Google Cloud Storage (si STORAGE_PROVIDER=gcs) ──
# [REQ-gcs] Bucket de ELG, público a nivel IAM (allUsers:Storage Object Viewer).
GCS_BUCKET_NAME="elg-pro-uploads"
# [OPC] Opcional si el JSON de credenciales ya trae project_id.
GCS_PROJECT_ID="tu-project-id"
# [REQ-gcs] gcs-key.json COMPLETO en una variable.
#  · en .env  → comillas SIMPLES (con dobles, dotenv expande los \n y rompe el JSON)
#  · en Vercel → pegar el JSON SIN comillas
GCS_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"svc@proyecto.iam.gserviceaccount.com"}'
# [OPC] Alternativa a GCS_CREDENTIALS_JSON: los dos campos sueltos.
# GCS_CLIENT_EMAIL="svc@proyecto.iam.gserviceaccount.com"
# GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Cloudinary (si STORAGE_PROVIDER=cloudinary) ──
# [OPC] Solo si usás Cloudinary en lugar de GCS.
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# ──────────────────────────────────────────────
# Email — Resend  (NO es SendGrid)
# ──────────────────────────────────────────────
# [REQ] API key de Resend.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# [REQ] From address. El DOMINIO debe estar verificado en Resend o no entrega.
EMAIL_FROM="ELG Pro <no-reply@tu-dominio-verificado>"

# ──────────────────────────────────────────────
# Portal en vivo (WebSocket + Redis) — OPCIONAL
# Sin estas el portal funciona, pero "dormido" (sin tiempo real).
# ──────────────────────────────────────────────
# [OPC] Redis donde el server publica snapshots de la OT.
REDIS_URL="redis://default:PASSWORD@HOST:PORT"
# [OPC] URL del WS server (cruza al browser → NUNCA secretos acá).
NEXT_PUBLIC_WS_URL="wss://tu-ws-server"

# ──────────────────────────────────────────────
# Runtime
# ──────────────────────────────────────────────
# [AUTO] "development" | "production" — la setea Next/Vercel. No la toques.
# NODE_ENV="development"